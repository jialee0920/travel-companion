# 환경 변수 (apps/companion) — `.env.local`로 복사 후 Secret key만 추가

# ─── Supabase (새 API Keys) ───
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# 서버 전용 — Vercel/로컬 .env.local (절대 NEXT_PUBLIC_ 붙이지 않음)
SUPABASE_SECRET_KEY=sb_secret_...

# Legacy (프로젝트에 anon/service_role JWT만 있을 때)
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# ─── PortOne(아임포트) 테스트 ───
NEXT_PUBLIC_PORTONE_STORE_ID=imp00000000
NEXT_PUBLIC_PORTONE_CHANNEL_KEY=imp00000000
PORTONE_API_SECRET=
PORTONE_API_KEY=

# ─── 솔라피 SMS OTP (선택 — 현재 로그인은 이름+연락처 간편 방식) ───
SOLAPI_API_KEY=
SOLAPI_API_SECRET=
SOLAPI_SENDER_PHONE=01012345678

# ─── Airtable (Users / OTP_Codes) ───
AIRTABLE_PERSONAL_ACCESS_TOKEN=pat...
AIRTABLE_BASE_ID=app...
AIRTABLE_USERS_TABLE=Users
AIRTABLE_OTP_CODES_TABLE=OTP_Codes

# ─── 세션 (서버 전용, 32바이트 이상 랜덤 문자열) ───
# 생성: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# 또는: openssl rand -base64 32
AUTH_SESSION_SECRET=

# 선택 — OTP 만료·재발송 간격 (기본 5분 / 60초)
# OTP_EXPIRES_MINUTES=5
# OTP_RESEND_COOLDOWN_SECONDS=60

# Supabase SQL: apps/companion/supabase/schema.sql 실행
# Realtime: Dashboard > Database > Replication > chat_messages
# Vercel Root Directory: apps/companion
