# 환경 변수 (apps/companion) — `.env.local`로 복사 후 Secret key만 추가

# ─── Supabase (새 API Keys) ───
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# 서버 전용 — Vercel/로컬 .env.local (절대 NEXT_PUBLIC_ 붙이지 않음)
SUPABASE_SECRET_KEY=sb_secret_...

# Legacy (프로젝트에 anon/service_role JWT만 있을 때)
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# ─── PortOne(아임포트) 테스트 ───
NEXT_PUBLIC_PORTONE_STORE_ID=imp00000000
NEXT_PUBLIC_PORTONE_CHANNEL_KEY=imp00000000
PORTONE_API_SECRET=
PORTONE_API_KEY=

# Supabase SQL: apps/companion/supabase/schema.sql 실행
# Realtime: Dashboard > Database > Replication > chat_messages
# Vercel Root Directory: apps/companion
