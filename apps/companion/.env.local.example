# 환경 변수 (apps/companion) — `.env.local`로 복사

# ─── PortOne(아임포트) 테스트 ───
NEXT_PUBLIC_PORTONE_STORE_ID=imp00000000
NEXT_PUBLIC_PORTONE_CHANNEL_KEY=imp00000000
PORTONE_API_SECRET=
PORTONE_API_KEY=

# ─── 솔라피 SMS OTP (선택 — 현재 로그인은 이름+연락처 간편 방식) ───
SOLAPI_API_KEY=
SOLAPI_API_SECRET=
SOLAPI_SENDER_PHONE=01012345678

# ─── Airtable ───
# Users: Phone, Name, Region, Avatar URL, Companion Seed ID (동행자 시드용, 선택),
#   Bio (Long text), Interest Category (Multiple select: 식사/운동/여행), Profile Completed (Checkbox),
#   Age (Number, 만 나이),
#   Latitude (Number), Longitude (Number),
#   Location Updated At (Date — 「시간 포함」 켜기, 필드명 정확히 일치)
# Products: Product ID, Region, Name, Description, Image URL, Seller Name, Category,
#   Ticket Label, Regular Price, Discount Rate, Target Count, Current Count, Group Buy Status
# Orders: Order Code, User ID, Product ID, Product Name, Participant Name, Participant Phone,
#   Region, Amount, Payment Status, Imp UID, Merchant UID
# Participants: User ID, Product ID, Display Name, Order Code
# Chat_Rooms: Region, Last Message At
# Chat_Room_Members: Room ID, User ID
# Chat_Messages: Room ID, Sender ID, Body
AIRTABLE_PERSONAL_ACCESS_TOKEN=pat...
AIRTABLE_BASE_ID=app...
AIRTABLE_USERS_TABLE=Users
AIRTABLE_OTP_CODES_TABLE=OTP_Codes
AIRTABLE_PRODUCTS_TABLE=Products
AIRTABLE_ORDERS_TABLE=Orders
AIRTABLE_PARTICIPANTS_TABLE=Participants
AIRTABLE_CHAT_ROOMS_TABLE=Chat_Rooms
AIRTABLE_CHAT_ROOM_MEMBERS_TABLE=Chat_Room_Members
AIRTABLE_CHAT_MESSAGES_TABLE=Chat_Messages

# ─── 세션 (서버 전용, 32바이트 이상 랜덤 문자열) ───
AUTH_SESSION_SECRET=

# 선택 — OTP 만료·재발송 간격 (기본 5분 / 60초)
# OTP_EXPIRES_MINUTES=5
# OTP_RESEND_COOLDOWN_SECONDS=60

# Vercel Root Directory: apps/companion
